{
  "name": "the-coding-sdk",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "module": "./index.ts",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./index.ts"
    },
    "./sdk-tools": {
      "types": "./dist/src/sdk-tools.d.ts",
      "default": "./sdk-tools.ts"
    },
    "./sdk-tools.js": {
      "types": "./dist/src/sdk-tools.d.ts",
      "default": "./sdk-tools.ts"
    }
  },
  "scripts": {
    "build:types": "tsc",
    "format": "bunx oxfmt --write .",
    "format:check": "bunx oxfmt --check .",
    "lint": "bunx oxlint --import-plugin src *.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "api-surface:check": "bun run build:types && bun run scripts/api-surface-check.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.2"
  }
}
